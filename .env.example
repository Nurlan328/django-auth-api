# Copy this file to .env and uncomment to use Postgres/Redis/RabbitMQ from docker-compose.
# Without these, the app falls back to SQLite + in-memory cache (no Docker needed),
# which is also what the tests use.

# DEBUG=True
# SECRET_KEY=replace-with-a-long-random-secret

# Postgres (docker-compose maps it to host port 5434)
# DATABASE_URL=postgres://app:app@localhost:5434/appdb

# Redis cache (docker-compose maps it to host port 6380)
# REDIS_URL=redis://localhost:6380/1

# RabbitMQ broker for Celery (docker-compose maps it to host port 5673)
# CELERY_BROKER_URL=amqp://guest:guest@localhost:5673//
